<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ZoraIQ — Marketing con IA</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#04080f;--bg2:#060c16;
  --surface:rgba(255,255,255,0.025);
  --border:rgba(255,255,255,0.07);
  --border-lit:rgba(150,200,255,0.18);
  --text:#dce8f5;--muted:rgba(180,205,225,0.45);
  --accent:#5ba8e5;--accent2:#8ecaff;--ice:#c4e0ff;
  --wa:#25D366;--wa-glow:rgba(37,211,102,0.35);
}
html{scroll-behavior:smooth;overflow-x:hidden}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;overflow-x:hidden;cursor:none}

/* CURSOR */
#cur{position:fixed;width:10px;height:10px;background:#fff;border-radius:50%;pointer-events:none;z-index:9999;mix-blend-mode:difference;transition:transform .2s;transform:translate(-50%,-50%)}
#cur-o{position:fixed;width:36px;height:36px;border:1px solid rgba(150,200,255,.4);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .3s,height .3s,border-color .3s}

/* INTRO */
#intro{position:fixed;inset:0;z-index:2000;background:#04080f;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0}
.ilw{opacity:0;transform:translateY(16px) scale(.94);display:flex;flex-direction:column;align-items:center;gap:6px}
.isub{font-size:11px;letter-spacing:.35em;text-transform:uppercase;color:var(--muted);opacity:0;margin-top:16px}
#ibar{position:absolute;bottom:0;left:0;height:1px;width:0;background:linear-gradient(to right,transparent,var(--accent2),transparent);transition:width 1s cubic-bezier(.23,1,.32,1)}

/* BG */
#bgw{position:fixed;inset:0;z-index:0}
#mc{position:absolute;inset:0;width:100%;height:100%}
#vig{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 65%,transparent 25%,rgba(4,8,15,.65) 75%,#04080f 100%);pointer-events:none}
#tf{position:absolute;top:0;left:0;right:0;height:32%;background:linear-gradient(to bottom,rgba(4,8,15,.9) 0%,transparent 100%);pointer-events:none}
#bf{position:absolute;bottom:0;left:0;right:0;height:42%;background:linear-gradient(to top,#04080f 0%,rgba(4,8,15,.55) 55%,transparent 100%);pointer-events:none}
#pc{position:fixed;inset:0;pointer-events:none;z-index:2;opacity:.65}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:22px 52px;display:flex;align-items:center;justify-content:space-between;transition:background .4s,border-color .4s}
nav.s{background:rgba(4,8,15,.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.nl{display:flex;gap:32px;align-items:center}
.nl a{font-size:13px;font-weight:400;color:var(--muted);text-decoration:none;letter-spacing:.04em;transition:color .2s}
.nl a:hover{color:var(--text)}
.nl .nc{padding:8px 20px;border:1px solid var(--border-lit);border-radius:100px;font-size:12px;color:var(--accent2)!important;transition:background .2s,box-shadow .2s}
.nl .nc:hover{background:rgba(150,200,255,.08);box-shadow:0 0 18px rgba(150,200,255,.15)}

/* HERO */
#hero{min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;flex-direction:column;padding:80px 24px 0;position:relative;z-index:10}
.hbadge{display:inline-flex;align-items:center;gap:8px;padding:5px 14px;border:1px solid var(--border-lit);border-radius:100px;background:rgba(91,168,229,.06);font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--accent2);margin-bottom:36px;opacity:0;transform:translateY(16px)}
.hbadge::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--wa);box-shadow:0 0 8px var(--wa);animation:bl 2s ease-in-out infinite}
@keyframes bl{0%,100%{opacity:1}50%{opacity:.2}}
.hh{font-size:clamp(34px,6vw,82px);font-weight:800;line-height:1.03;letter-spacing:-.035em;color:#fff;opacity:0;transform:translateY(28px);max-width:860px}
.hh em{font-style:normal;background:linear-gradient(135deg,var(--ice) 0%,var(--accent) 60%);-webkit-background-clip:text;background-clip:text;color:transparent}
.hp{font-size:clamp(14px,1.8vw,18px);font-weight:300;color:var(--muted);max-width:520px;line-height:1.75;opacity:0;transform:translateY(16px);margin-top:22px;margin-bottom:44px}
.bwa{display:inline-flex;align-items:center;gap:11px;padding:15px 34px;border-radius:100px;background:var(--wa);color:#fff;font-size:14px;font-weight:600;text-decoration:none;letter-spacing:.02em;box-shadow:0 0 28px var(--wa-glow),0 0 60px rgba(37,211,102,.15);transition:transform .3s cubic-bezier(.23,1,.32,1),box-shadow .3s;opacity:0;transform:translateY(16px);position:relative;overflow:hidden}
.bwa::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.18),transparent);opacity:0;transition:opacity .3s}
.bwa:hover{transform:translateY(-3px) scale(1.02)!important;box-shadow:0 0 50px var(--wa-glow),0 20px 40px rgba(0,0,0,.35)}
.bwa:hover::after{opacity:1}
.pr{position:absolute;inset:-3px;border-radius:100px;border:1px solid var(--wa);animation:prr 2.5s ease-out infinite;opacity:0}
@keyframes prr{0%{transform:scale(1);opacity:.5}100%{transform:scale(1.14);opacity:0}}
.sind{position:absolute;bottom:44px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0}
.sind span{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted)}
.sl{width:1px;height:36px;background:linear-gradient(to bottom,var(--accent2),transparent);animation:sa 2s ease-in-out infinite}
@keyframes sa{0%,100%{opacity:1;transform:scaleY(1)}50%{opacity:.3;transform:scaleY(.5)}}

/* SECTIONS */
section{position:relative;z-index:10}
.wrap{max-width:1160px;margin:0 auto;padding:0 44px}
.seye{font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);font-weight:500;display:flex;align-items:center;gap:10px;margin-bottom:14px}
.seye::before{content:'';width:28px;height:1px;background:var(--accent);opacity:.5}
.sh{font-size:clamp(26px,3.8vw,50px);font-weight:700;letter-spacing:-.028em;line-height:1.15;color:#fff}
.sh span{background:linear-gradient(135deg,var(--accent2),var(--accent));-webkit-background-clip:text;background-clip:text;color:transparent}

/* STATS */
#stats{padding:80px 0}
.srow{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:14px;overflow:hidden}
.st{background:var(--bg2);padding:40px 32px;text-align:center}
.stn{font-size:clamp(26px,4vw,42px);font-weight:800;letter-spacing:-.03em;background:linear-gradient(135deg,var(--ice),var(--accent));-webkit-background-clip:text;background-clip:text;color:transparent}
.stl{font-size:12px;color:var(--muted);margin-top:6px;letter-spacing:.04em}

/* SERVICES */
#services{padding:130px 0}
.sgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-top:60px}
.svc{background:var(--bg);padding:44px 36px 56px;position:relative;overflow:hidden;transition:background .35s}
.svc::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% -10%,rgba(91,168,229,.07),transparent 60%);opacity:0;transition:opacity .5s}
.svc:hover{background:#060e1c}
.svc:hover::after{opacity:1}
.sico{width:36px;height:36px;margin-bottom:24px;transition:opacity .3s;opacity:.7}
.svc:hover .sico{opacity:1}
.svct{font-size:16px;font-weight:600;color:#fff;margin-bottom:10px;letter-spacing:-.015em}
.svcd{font-size:13.5px;line-height:1.8;color:var(--muted);font-weight:300}
.svcr{position:absolute;bottom:32px;right:32px;width:26px;height:26px;border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;transition:border-color .3s,transform .3s}
.svc:hover .svcr{border-color:var(--accent);transform:rotate(45deg)}
.svcr svg{width:10px;height:10px;stroke:var(--muted);transition:stroke .3s;fill:none;stroke-width:1.5;stroke-linecap:round}
.svc:hover .svcr svg{stroke:var(--accent2)}

/* BENEFITS */
#benefits{padding:130px 0}
.blayout{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.bvis{position:relative;aspect-ratio:1;width:100%;display:flex;align-items:center;justify-content:center}
.br{position:absolute;border-radius:50%;border:1px solid;top:50%;left:50%;transform:translate(-50%,-50%)}
.br1{width:60%;height:60%;border-color:rgba(91,168,229,.25);animation:sp 22s linear infinite}
.br2{width:80%;height:80%;border-color:rgba(142,202,255,.12);animation:sp 35s linear infinite reverse}
.br3{width:100%;height:100%;border-color:rgba(91,168,229,.06);animation:sp 52s linear infinite}
@keyframes sp{to{transform:translate(-50%,-50%) rotate(360deg)}}
.br1::after{content:'';position:absolute;width:6px;height:6px;background:var(--accent2);border-radius:50%;top:-3px;left:50%;transform:translateX(-50%);box-shadow:0 0 10px var(--accent2)}
.bcore{width:108px;height:108px;border-radius:50%;border:1px solid rgba(91,168,229,.35);background:radial-gradient(circle,rgba(91,168,229,.18),rgba(91,168,229,.04));display:flex;align-items:center;justify-content:center;box-shadow:0 0 40px rgba(91,168,229,.12),inset 0 0 30px rgba(91,168,229,.06)}
.blist{display:flex;flex-direction:column;margin-top:44px}
.bit{display:flex;gap:18px;padding:26px 0;border-bottom:1px solid var(--border);align-items:flex-start;opacity:0;transform:translateX(18px)}
.bin{font-size:11px;font-weight:600;color:var(--accent);letter-spacing:.08em;flex-shrink:0;margin-top:2px}
.bitt{font-size:15px;font-weight:600;color:#fff;margin-bottom:5px;letter-spacing:-.01em}
.bitd{font-size:13.5px;line-height:1.75;color:var(--muted);font-weight:300}

/* TESTIMONIALS */
#testimonials{padding:130px 0}
.tg{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:60px}
.tc{padding:32px 28px;border-radius:12px;border:1px solid var(--border);background:var(--surface);position:relative;overflow:hidden;transition:border-color .3s,transform .3s;opacity:0;transform:translateY(24px)}
.tc::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,rgba(91,168,229,.22),transparent);opacity:0;transition:opacity .3s}
.tc:hover{border-color:var(--border-lit);transform:translateY(-5px)}
.tc:hover::before{opacity:1}
.tstar{display:flex;gap:3px;margin-bottom:18px}
.ts{width:11px;height:11px;fill:#f59e0b}
.tq{font-size:13px;line-height:1.8;color:var(--muted);font-weight:300;margin-bottom:24px;font-style:italic}
.tau{display:flex;align-items:center;gap:11px}
.tav{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--accent),#6366f1);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0}
.tn{font-size:13px;font-weight:600;color:#fff}
.tr{font-size:11px;color:var(--muted);margin-top:2px}

/* CTA */
#cta{padding:130px 0 150px}
.cbox{border-radius:20px;padding:80px 56px;text-align:center;border:1px solid var(--border-lit);background:radial-gradient(ellipse at 50% 0%,rgba(91,168,229,.1),rgba(4,8,15,.92) 65%);position:relative;overflow:hidden}
.cbox::before{content:'';position:absolute;top:-1px;left:25%;right:25%;height:1px;background:linear-gradient(to right,transparent,var(--accent2),transparent)}
.ch{font-size:clamp(26px,4.5vw,56px);font-weight:800;letter-spacing:-.03em;color:#fff;margin-bottom:18px}
.cp{font-size:15px;font-weight:300;color:var(--muted);max-width:440px;margin:0 auto 42px;line-height:1.7}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:40px 0}
.fi{max-width:1160px;margin:0 auto;padding:0 44px;display:flex;align-items:center;justify-content:space-between}
.fc{font-size:12px;color:var(--muted)}

/* AMBIENT */
.amb{position:fixed;border-radius:50%;pointer-events:none;z-index:1;filter:blur(90px)}
#a1{width:700px;height:700px;background:radial-gradient(circle,rgba(91,168,229,.045),transparent 70%);top:-200px;left:-200px;animation:dr1 22s ease-in-out infinite}
#a2{width:500px;height:500px;background:radial-gradient(circle,rgba(142,202,255,.035),transparent 70%);bottom:-100px;right:-100px;animation:dr2 28s ease-in-out infinite}
@keyframes dr1{0%,100%{transform:translate(0,0)}50%{transform:translate(80px,60px)}}
@keyframes dr2{0%,100%{transform:translate(0,0)}50%{transform:translate(-60px,-50px)}}

/* REVEAL */
.rv{opacity:0;transform:translateY(32px);transition:opacity .85s cubic-bezier(.23,1,.32,1),transform .85s cubic-bezier(.23,1,.32,1)}
.rv.on{opacity:1;transform:translateY(0)}

/* MOBILE */
@media(max-width:768px){
  nav{padding:16px 20px}.nl{display:none}.wrap{padding:0 20px}
  .sgrid{grid-template-columns:1fr}.blayout{grid-template-columns:1fr}.bvis{display:none}
  .tg{grid-template-columns:1fr}.srow{grid-template-columns:repeat(2,1fr)}
  .cbox{padding:44px 22px}.fi{flex-direction:column;gap:14px;text-align:center}
}
</style>
</head>
