<script>
// ══════════════════════════════════════════════
// MOUNTAIN CANVAS — Ultra Photorealistic
// ══════════════════════════════════════════════
(function(){
  const cv=document.getElementById('mc'),cx=cv.getContext('2d');
  let W,H,T=0,SY=0;
  function rsz(){W=cv.width=window.innerWidth;H=cv.height=window.innerHeight}
  rsz();window.addEventListener('resize',rsz);
  window.addEventListener('scroll',()=>SY=window.scrollY);

  // Value noise
  function vn(n){n=(n<<13)^n;return 1-(((n*(n*n*15731+789221)+1376312589)&0x7fffffff)/1073741824)}
  function sn(x,s=0){
    const i=Math.floor(x),f=x-i,u=f*f*(3-2*f);
    return vn(i+s*997)*(1-u)+vn(i+1+s*997)*u;
  }
  function fbm(x,o,s=0){
    let v=0,a=.5,f=1,m=0;
    for(let i=0;i<o;i++){v+=sn(x*f,s+i*13)*a;m+=a;a*=.52;f*=2.15;}
    return v/m;
  }

  function prof(bY,amp,rough,seed,ox=0){
    const pts=[];
    for(let px=0;px<=W;px+=3){
      const nx=px/W;
      let n=fbm(nx*rough+ox,7,seed);
      const d=nx-.5,bell=Math.exp(-d*d*6)*.7+Math.exp(-d*d*1.8)*.3;
      const rock=fbm(nx*rough*2.5+ox+50,4,seed+5)*.1*(1-bell);
      pts.push({x:px,y:bY-(n*.28+bell*.72+rock)*amp});
    }
    return pts;
  }

  function fill(pts,g){
    cx.beginPath();cx.moveTo(0,H+60);
    pts.forEach(p=>cx.lineTo(p.x,p.y));
    cx.lineTo(W,H+60);cx.closePath();
    cx.fillStyle=g;cx.fill();
  }

  function ridge(pts,col,lw){
    cx.beginPath();pts.forEach((p,i)=>i?cx.lineTo(p.x,p.y):cx.moveTo(p.x,p.y));
    cx.strokeStyle=col;cx.lineWidth=lw;cx.stroke();
  }

  function snow(pts,thr,op=1){
    cx.save();cx.globalAlpha=op;
    cx.beginPath();cx.moveTo(0,H+60);
    pts.forEach(p=>{cx.lineTo(p.x,Math.max(p.y,Math.min(p.y,thr+1)));});
    // Build proper snow shape
    cx.beginPath();cx.moveTo(0,H+60);
    for(let i=0;i<pts.length;i++){
      if(pts[i].y<=thr)cx.lineTo(pts[i].x,pts[i].y);
      else cx.lineTo(pts[i].x,thr+2);
    }
    cx.lineTo(W,H+60);cx.closePath();
    const sg=cx.createLinearGradient(0,thr-60,0,thr+20);
    sg.addColorStop(0,'rgba(238,248,255,.97)');
    sg.addColorStop(.25,'rgba(210,232,255,.9)');
    sg.addColorStop(.55,'rgba(170,210,252,.6)');
    sg.addColorStop(1,'rgba(120,175,245,.08)');
    cx.fillStyle=sg;cx.fill();cx.restore();
  }

  function fog(y,h,op){
    cx.save();cx.globalAlpha=op;
    const drift=Math.sin(T*.22)*28+Math.cos(T*.14)*16;
    const g=cx.createLinearGradient(0,y-h,0,y+h);
    g.addColorStop(0,'transparent');
    g.addColorStop(.35,'rgba(16,36,70,.5)');
    g.addColorStop(.5,'rgba(22,46,88,.65)');
    g.addColorStop(.65,'rgba(16,36,70,.5)');
    g.addColorStop(1,'transparent');
    cx.fillStyle=g;cx.fillRect(0,y-h+drift,W,h*2);
    cx.globalAlpha=op*.35;cx.fillRect(0,y-h*.5-drift*.6,W,h*1.1);
    cx.restore();
  }

  function glow(x,y,r,col){
    const g=cx.createRadialGradient(x,y,0,x,y,r);
    g.addColorStop(0,col);g.addColorStop(1,'transparent');
    cx.fillStyle=g;cx.fillRect(x-r,y-r,r*2,r*2);
  }

  function stars(){
    cx.save();
    for(let i=0;i<300;i++){
      const x=((i*1618.034+80)%W),y=((i*987.654+50)%(H*.58));
      const tw=Math.sin(T*.7+i*2.3)*.32+.68,sz=.35+((i*233.7)%10)/16;
      cx.beginPath();cx.arc(x,y,sz,0,Math.PI*2);
      const cold=i%4===0;
      cx.fillStyle=cold?`rgba(175,218,255,${tw*.75})`:`rgba(215,232,255,${tw*.5})`;
      cx.fill();
      if(i%22===0){
        cx.strokeStyle=`rgba(200,228,255,${tw*.55})`;cx.lineWidth=.35;
        cx.beginPath();cx.moveTo(x-sz*5,y);cx.lineTo(x+sz*5,y);cx.stroke();
        cx.beginPath();cx.moveTo(x,y-sz*5);cx.lineTo(x,y+sz*5);cx.stroke();
      }
    }
    cx.restore();
  }

  function aurora(){
    cx.save();cx.globalAlpha=.06+Math.sin(T*.28)*.018;
    const ay=H*.28;
    const ag=cx.createLinearGradient(0,ay-70,0,ay+70);
    ag.addColorStop(0,'transparent');
    ag.addColorStop(.3,'rgba(35,120,195,.65)');
    ag.addColorStop(.5,'rgba(50,150,215,.85)');
    ag.addColorStop(.7,'rgba(35,120,195,.55)');
    ag.addColorStop(1,'transparent');
    cx.fillStyle=ag;
    cx.beginPath();cx.moveTo(0,ay);
    for(let x=0;x<=W;x+=18){
      const w=Math.sin(x/W*Math.PI*4.5+T*.38)*22+Math.cos(x/W*Math.PI*7+T*.22)*12;
      cx.lineTo(x,ay+w);
    }
    cx.lineTo(W,ay-55);cx.lineTo(0,ay-55);cx.closePath();cx.fill();cx.restore();
  }

  function draw(t){
    T=t*.001;cx.clearRect(0,0,W,H);
    const par=SY*.2;
    cx.save();cx.translate(0,par);

    // Sky
    const sk=cx.createLinearGradient(0,0,0,H*.85);
    sk.addColorStop(0,'#010209');sk.addColorStop(.12,'#01040d');
    sk.addColorStop(.35,'#020612');sk.addColorStop(.6,'#030b1c');
    sk.addColorStop(.8,'#040d20');sk.addColorStop(1,'#030b1c');
    cx.fillStyle=sk;cx.fillRect(0,0,W,H);

    stars();
    aurora();

    // Moon
    const mx=W*.73,my=H*.1;
    [{r:220,a:.025},{r:110,a:.055},{r:55,a:.1},{r:22,a:.22}].forEach(({r,a})=>glow(mx,my,r,`rgba(170,215,255,${a})`));
    cx.save();cx.beginPath();cx.arc(mx,my,15,0,Math.PI*2);
    const mg=cx.createRadialGradient(mx-3,my-3,1,mx,my,15);
    mg.addColorStop(0,'rgba(248,252,255,1)');mg.addColorStop(.5,'rgba(205,232,255,.95)');mg.addColorStop(1,'rgba(135,185,245,.4)');
    cx.fillStyle=mg;cx.fill();
    cx.beginPath();cx.arc(mx+4,my-1,12,0,Math.PI*2);
    cx.fillStyle='rgba(2,7,18,.5)';cx.fill();cx.restore();

    const BY=H*.70,AMP=H*.57;

    // Far range
    const p3=prof(BY+90,AMP*.4,1.5,71,.7);
    const g3=cx.createLinearGradient(0,BY-AMP*.4,0,BY+90);
    g3.addColorStop(0,'#07101e');g3.addColorStop(1,'#030810');
    fill(p3,g3);

    // Mid range
    const p2=prof(BY+35,AMP*.65,1.9,31,.22);
    const g2=cx.createLinearGradient(0,BY-AMP*.65,0,BY+35);
    g2.addColorStop(0,'#0b1929');g2.addColorStop(.5,'#081422');g2.addColorStop(1,'#050c1a');
    fill(p2,g2);ridge(p2,'rgba(45,95,175,.1)',1);
    snow(p2,BY-AMP*.43,.65);

    // Fog
    fog(BY,BY-AMP*.32,50,.55);fog(BY,BY-AMP*.52,32,.25);

    // MAIN PEAK
    const p0=prof(BY,AMP,2.9,7,0);
    // Body
    const g0=cx.createLinearGradient(0,BY-AMP,0,BY);
    g0.addColorStop(0,'#111e30');g0.addColorStop(.15,'#0d192a');
    g0.addColorStop(.38,'#091422');g0.addColorStop(.62,'#060e1a');
    g0.addColorStop(.82,'#04090f');g0.addColorStop(1,'#030810');
    fill(p0,g0);
    // Moonlight sheen on right face
    cx.save();
    const rf=cx.createLinearGradient(W*.65,BY-AMP,W*.35,BY);
    rf.addColorStop(0,'rgba(75,140,225,.07)');rf.addColorStop(.5,'transparent');rf.addColorStop(1,'rgba(0,4,12,.12)');
    cx.fillStyle=rf;
    cx.beginPath();cx.moveTo(0,H+60);p0.forEach(p=>cx.lineTo(p.x,p.y));cx.lineTo(W,H+60);cx.closePath();cx.fill();cx.restore();
    ridge(p0,'rgba(85,155,255,.16)',1.8);

    // Snow
    const peak=p0.reduce((a,b)=>a.y<b.y?a:b);
    const snLine=peak.y+AMP*.31;
    snow(p0,snLine);
    // Ice rim at snow line
    cx.save();cx.globalAlpha=.5;
    const ir=p0.filter(p=>p.y>=snLine-12&&p.y<=snLine+18);
    if(ir.length>1){cx.beginPath();ir.forEach((p,i)=>i?cx.lineTo(p.x,p.y):cx.moveTo(p.x,p.y));cx.strokeStyle='rgba(195,232,255,.35)';cx.lineWidth=1.3;cx.stroke();}
    cx.restore();

    // Summit glow
    [{r:110,a:.07},{r:44,a:.13},{r:14,a:.28}].forEach(({r,a})=>glow(peak.x,peak.y,r,`rgba(175,225,255,${a})`));

    // Cloud clinging to upper peak
    fog(BY,peak.y+AMP*.14,36,.32);

    // Foreground dark hill
    const pf=prof(BY+H*.24,AMP*.33,3.2,53,1.4);
    const gf=cx.createLinearGradient(0,BY,0,H+60);
    gf.addColorStop(0,'#030912');gf.addColorStop(1,'#020408');
    fill(pf,gf);

    cx.restore();
    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();

// ══════════════════════════════════════════════
// PARTICLES
// ══════════════════════════════════════════════
(function(){
  const cv=document.getElementById('pc'),cx=cv.getContext('2d');
  let W,H;
  function rsz(){W=cv.width=window.innerWidth;H=cv.height=window.innerHeight}
  rsz();window.addEventListener('resize',rsz);
  const ps=Array.from({length:65},()=>({x:Math.random()*1000,y:Math.random()*900,vx:(Math.random()-.5)*.22,vy:-Math.random()*.32-.06,sz:Math.random()*1.7+.4,a:Math.random()*.3+.06,life:Math.random()}));
  function rnd(){
    cx.clearRect(0,0,W,H);
    ps.forEach(p=>{
      p.x+=p.vx;p.y+=p.vy;p.life+=.0022;
      if(p.y<-5||p.life>1){p.x=Math.random()*W;p.y=H+5;p.life=0}
      const a=Math.sin(p.life*Math.PI)*p.a;
      cx.beginPath();cx.arc(p.x,p.y,p.sz,0,Math.PI*2);
      cx.fillStyle=`rgba(155,208,255,${a})`;cx.fill();
    });
    requestAnimationFrame(rnd);
  }
  requestAnimationFrame(rnd);
})();

// ══════════════════════════════════════════════
// CURSOR
// ══════════════════════════════════════════════
(function(){
  const c=document.getElementById('cur'),r=document.getElementById('cur-o');
  let mx=-100,my=-100,rx=-100,ry=-100;
  document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});
  function lp(){
    c.style.left=mx+'px';c.style.top=my+'px';
    rx+=(mx-rx)*.1;ry+=(my-ry)*.1;
    r.style.left=rx+'px';r.style.top=ry+'px';
    requestAnimationFrame(lp);
  }
  lp();
  document.querySelectorAll('a').forEach(el=>{
    el.addEventListener('mouseenter',()=>{c.style.transform='translate(-50%,-50%) scale(2.5)';r.style.width='55px';r.style.height='55px';r.style.borderColor='rgba(37,211,102,.5)'});
    el.addEventListener('mouseleave',()=>{c.style.transform='translate(-50%,-50%) scale(1)';r.style.width='36px';r.style.height='36px';r.style.borderColor='rgba(150,200,255,.4)'});
  });
})();

// ══════════════════════════════════════════════
// INTRO
// ══════════════════════════════════════════════
(function(){
  const intro=document.getElementById('intro'),ilw=document.getElementById('ilw'),isub=document.getElementById('isub'),bar=document.getElementById('ibar'),main=document.getElementById('main');
  // Glow orbs
  for(let i=0;i<22;i++){
    const d=document.createElement('div'),sz=Math.random()*80+20;
    d.style.cssText=`position:absolute;border-radius:50%;width:${sz}px;height:${sz}px;left:${Math.random()*100}%;top:${Math.random()*100}%;background:radial-gradient(circle,rgba(${Math.random()>.5?'91,168,229':'142,202,255'},${Math.random()*.16+.04}),transparent);filter:blur(${sz*.32}px);transform:translate(-50%,-50%);pointer-events:none;transition:opacity ${Math.random()*.9+.4}s;opacity:0`;
    intro.appendChild(d);setTimeout(()=>d.style.opacity='1',Math.random()*500);
  }
  setTimeout(()=>{ilw.style.transition='opacity 1.1s cubic-bezier(.23,1,.32,1),transform 1.1s cubic-bezier(.23,1,.32,1)';ilw.style.opacity='1';ilw.style.transform='translateY(0) scale(1)'},300);
  setTimeout(()=>{isub.style.transition='opacity .9s ease';isub.style.opacity='1'},820);
  setTimeout(()=>bar.style.width='100%',1100);
  setTimeout(()=>{
    intro.style.transition='opacity .85s cubic-bezier(.23,1,.32,1)';intro.style.opacity='0';
    setTimeout(()=>{intro.style.display='none';main.style.transition='opacity .65s ease';main.style.opacity='1';animHero()},860);
  },2650);
})();

function animHero(){
  [['hb',0],['hh',.14],['hp',.27],['hwb',.41],['si',.62]].forEach(([id,d])=>{
    const el=document.getElementById(id);if(!el)return;
    el.style.transition=`opacity .9s ${d}s cubic-bezier(.23,1,.32,1),transform .9s ${d}s cubic-bezier(.23,1,.32,1)`;
    el.style.opacity='1';el.style.transform='translateY(0)';
  });
}

// ══════════════════════════════════════════════
// SCROLL
// ══════════════════════════════════════════════
(function(){
  const nav=document.getElementById('nav');
  window.addEventListener('scroll',()=>nav.classList.toggle('s',scrollY>50));

  // Reveal
  const obs=new IntersectionObserver(es=>{
    es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('on');obs.unobserve(e.target)}});
  },{threshold:.1,rootMargin:'0px 0px -35px 0px'});
  document.querySelectorAll('.rv').forEach(r=>obs.observe(r));

  // Benefits stagger
  const bits=document.querySelectorAll('.bit');
  const bo=new IntersectionObserver(es=>{
    es.forEach(e=>{
      if(e.isIntersecting){
        const i=Array.from(bits).indexOf(e.target);
        setTimeout(()=>{e.target.style.transition='opacity .7s ease,transform .7s ease';e.target.style.opacity='1';e.target.style.transform='translateX(0)'},i*105);
        bo.unobserve(e.target);
      }
    });
  },{threshold:.08});
  bits.forEach(b=>bo.observe(b));

  // Testimonials stagger
  const tcs=document.querySelectorAll('.tc');
  const to=new IntersectionObserver(es=>{
    es.forEach(e=>{
      if(e.isIntersecting){
        const i=Array.from(tcs).indexOf(e.target);
        setTimeout(()=>{e.target.style.transition='opacity .8s ease,transform .8s ease';e.target.style.opacity='1';e.target.style.transform='translateY(0)'},i*130);
        to.unobserve(e.target);
      }
    });
  },{threshold:.08});
  tcs.forEach(t=>to.observe(t));

  // Service cards stagger
  const svcs=document.querySelectorAll('.svc');
  svcs.forEach(s=>{s.style.opacity='0';s.style.transform='translateY(16px)'});
  const so=new IntersectionObserver(es=>{
    es.forEach(e=>{
      if(e.isIntersecting){
        const i=Array.from(svcs).indexOf(e.target);
        setTimeout(()=>{e.target.style.transition='opacity .7s ease,transform .7s ease';e.target.style.opacity='1';e.target.style.transform='translateY(0)'},i*85);
        so.unobserve(e.target);
      }
    });
  },{threshold:.08});
  svcs.forEach(s=>so.observe(s));
})();
</script>
